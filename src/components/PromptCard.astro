---
// A copy-paste prompt template with a copy button.
// Usage: <PromptCard title="...">plain markdown prompt text</PromptCard>
interface Props {
  title?: string;
}
const { title = 'Prompt template' } = Astro.props;
---

<figure class="prompt-card">
  <figcaption>
    <span class="prompt-title">💬 {title}</span>
    <button class="copy-btn" type="button" aria-label="Copy prompt">Copy</button>
  </figcaption>
  <div class="prompt-body">
    <slot />
  </div>
</figure>

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.prompt-card .copy-btn')) {
    btn.addEventListener('click', async () => {
      const body = btn.closest('.prompt-card')?.querySelector('.prompt-body');
      const text = body?.textContent?.trim();
      if (!text) return;
      await navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      setTimeout(() => {
        btn.textContent = 'Copy';
      }, 1500);
    });
  }
</script>

<style>
  .prompt-card {
    margin: 1rem 0;
    border: 1px solid var(--sl-color-gray-5);
    border-inline-start: 4px solid var(--sl-color-accent);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-6);
    overflow: hidden;
  }
  figcaption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 1rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
    font-weight: 600;
  }
  .copy-btn {
    padding: 0.1rem 0.6rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.35rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    font-size: var(--sl-text-xs);
    cursor: pointer;
  }
  .copy-btn:hover {
    border-color: var(--sl-color-accent);
  }
  .prompt-body {
    padding: 0.5rem 1rem;
    font-size: var(--sl-text-sm);
  }
</style>
